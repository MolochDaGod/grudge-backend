# Database
DATABASE_URL=postgresql://grudge:CHANGE_ME@localhost:5432/grudge_game

# Server
PORT=5000
NODE_ENV=production

# JWT
JWT_SECRET=CHANGE_ME_generate_64_char_random_string

# Crossmint Server-Side Wallets
CROSSMINT_API_KEY=your_crossmint_server_api_key
CROSSMINT_BASE_URL=https://www.crossmint.com/api/v1-alpha2

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://api.grudge-studio.com/auth/discord/callback

# AI Agents (Gemini)
GEMINI_API_KEY=

# CORS
CORS_ORIGINS=https://grudgewarlords.com,https://grudge-studio.com,http://localhost:5173

# Frontend URL (for OAuth redirects)
FRONTEND_URL=https://grudgewarlords.com
